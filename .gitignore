# ─────────────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
secrets/
.secrets/
credentials/
*.secret
vault-config.hcl

# ─────────────────────────────────────────────────────────────────
# 🧪 TESTING & QUALITY
#    tests/
#    ├── unit/               → Per-service unit tests
#    ├── integration/        → Cross-service API tests
#    ├── e2e/                → End-to-end Cypress/Playwright
#    └── fixtures/           → Test data (farmer mocks, images)
# ─────────────────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
*.cover
*.log
nosetests.xml
test-results/
junit.xml
playwright-report/

